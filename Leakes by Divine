--// CLIPBOARD FUNCTION
local function CopyToClipboard(text)
	if setclipboard then
		setclipboard(text)
	elseif toclipboard then
		toclipboard(text)
	end
end

--// SECTION CREATOR
local function CreateLeakSection(sectionName, link, hasLoadButton)

	MainTab:CreateSection(sectionName)

	if hasLoadButton then
		MainTab:CreateButton({
			Name = "Load",
			Callback = function()

				local success, err = pcall(function()
					loadstring(game:HttpGet("https://pastebin.com/raw/q6sjKVgb"))()
				end)

				if not success then
					Rayfield:Notify({
						Title = "Error",
						Content = tostring(err),
						Duration = 5
					})
				end

			end
		})
	end

	MainTab:CreateButton({
		Name = "Copy Link",
		Callback = function()

			CopyToClipboard(link)

			Rayfield:Notify({
				Title = "Copied",
				Content = "Link copied to clipboard",
				Duration = 3
			})

		end
	})
end

